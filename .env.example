# === JWT (REQUIRED) ===
# Must be set — the backend will not start without this value.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS_MINIMUM

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# === Vast.ai ===
VAST_API_KEY=your_vast_api_key_here

# === PostgreSQL ===
POSTGRES_DB=btcpay
POSTGRES_USER=btcpay
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# asyncpg driver — host is the Docker service name, not localhost
DATABASE_URL=postgresql+asyncpg://btcpay:CHANGE_ME_STRONG_PASSWORD@postgres:5432/btcpay

# === BTCPay Root URI ===
BTCPAY_ROOT_URI=https://btcpay.mozartgpu.com

# === BTCPay Server ===
BTCPAY_STORE_ID=your_store_id
BTCPAY_API_KEY=your_btcpay_api_key
BTCPAY_WEBHOOK_SECRET=your_webhook_secret

# === App ===
PROVISION_WEBHOOK_PORT=8081
